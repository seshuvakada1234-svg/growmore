
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a registered user's profile information.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "affiliate"] },
        "affiliateStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected", "disabled"] },
        "referralCode": { "type": "string" },
        "totalClicks": { "type": "number" },
        "totalEarnings": { "type": "number" },
        "paidEarnings": { "type": "number" },
        "totalReferrals": { "type": "number" },
        "bankAccountName": { "type": "string" },
        "bankAccountNumber": { "type": "string" },
        "bankIfscCode": { "type": "string" },
        "upiId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "affiliateCommission": { "type": "number", "description": "Percentage 0-10" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "referrerUserId": { "type": "string", "nullable": true },
        "commissionAmount": { "type": "number" },
        "rejectedSelfReferral": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Payout": {
      "title": "Payout",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "affiliateId": { "type": "string" },
        "payoutAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "payoutDate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/users/{userId}/affiliateProfile/payouts/{payoutId}", "definition": { "entityName": "Payout" } },
      { "path": "/products/{productId}", "definition": { "entityName": "Product" } },
      { "path": "/orders/{orderId}", "definition": { "entityName": "Order" } },
      { "path": "/affiliateClicks/{clickId}", "definition": { "entityName": "AffiliateClick" } },
      { "path": "/roles_admin/{userId}", "definition": { "entityName": "UserProfile" } }
    ]
  }
}
