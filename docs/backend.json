
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "affiliate"] },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserAddress": {
      "title": "UserAddress",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "altPhone": { "type": "string" },
        "pincode": { "type": "string" },
        "state": { "type": "string" },
        "city": { "type": "string" },
        "house": { "type": "string" },
        "area": { "type": "string" },
        "landmark": { "type": "string" },
        "type": { "type": "string", "enum": ["Home", "Work"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AffiliateApplication": {
      "title": "AffiliateApplication",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AffiliateProfile": {
      "title": "AffiliateProfile",
      "type": "object",
      "properties": {
        "affiliateId": { "type": "string" },
        "totalEarnings": { "type": "number", "default": 0 },
        "paidEarnings": { "type": "number", "default": 0 },
        "totalClicks": { "type": "number", "default": 0 },
        "totalReferrals": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AffiliateCommission": {
      "title": "AffiliateCommission",
      "type": "object",
      "properties": {
        "affiliateId": { "type": "string" },
        "orderId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["unpaid", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AffiliatePayout": {
      "title": "AffiliatePayout",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "processedAt": { "type": "string", "format": "date-time" },
        "processedBy": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "/users/{userId}": { "schema": { "$ref": "#/entities/UserProfile" }, "description": "Global user roles" },
    "/users/{userId}/addresses/{addressId}": { "schema": { "$ref": "#/entities/UserAddress" }, "description": "Saved user delivery addresses" },
    "/affiliateApplications/{userId}": { "schema": { "$ref": "#/entities/AffiliateApplication" }, "description": "Pending applications" },
    "/affiliateProfiles/{userId}": { "schema": { "$ref": "#/entities/AffiliateProfile" }, "description": "Earnings and stats" },
    "/affiliateProfiles/{userId}/commissions/{id}": { "schema": { "$ref": "#/entities/AffiliateCommission" }, "description": "Individual earning logs" },
    "/affiliateProfiles/{userId}/payouts/{id}": { "schema": { "$ref": "#/entities/AffiliatePayout" }, "description": "Withdrawal requests" },
    "/affiliateClicks/{id}": { "schema": "object", "description": "Raw click logs" },
    "/orders/{orderId}": { "schema": "object", "description": "Orders with referral attribution" }
  }
}
