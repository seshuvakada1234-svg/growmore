
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GreenScape Nursery Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model combined with administrative access 
     * controlled via a dedicated "Existence over Content" collection.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      
      // Allow standard updates for owners/admins. 
      // Public increment of totalClicks is restricted by key comparison logic
      allow update: if (isExistingOwner(userId) || isAdmin()) || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalClicks']) && 
                     (resource.data.totalClicks == null ? request.resource.data.totalClicks == 1 : request.resource.data.totalClicks == resource.data.totalClicks + 1));
      
      allow delete: if isAdmin();

      match /addresses/{addressId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }

      match /cartItems/{cartItemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if (isExistingOwner(userId) && request.resource.data.userId == resource.data.userId);
        allow delete: if isExistingOwner(userId);
      }

      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin();
        
        // RULE: Prevent self-commission. referrerUserId must NOT be the same as the buyer UID.
        allow create: if isOwner(userId) && 
                      request.resource.data.userId == userId &&
                      (!('referrerUserId' in request.resource.data) || request.resource.data.referrerUserId != userId) &&
                      !('commissionAmount' in request.resource.data); // Client cannot set commissionAmount
        
        allow update: if isAdmin(); // Only admin can update global status or commissionAmount
        allow delete: if isAdmin();

        match /orderItems/{orderItemId} {
          allow get, list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId);
          allow update: if isAdmin();
          allow delete: if isAdmin();
        }
      }

      match /affiliateProfile {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
        allow delete: if isAdmin();

        match /payouts/{payoutId} {
          allow get, list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId) && request.resource.data.status == 'pending';
          allow update, delete: if isAdmin();
        }
      }
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /reviews/{reviewId} {
        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(resource.data.userId) || isAdmin();
      }
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin(); 
    }

    match /affiliateClicks/{clickId} {
      allow create: if true; 
      allow read, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get, list: if isAdmin();
      // Users write their orders to the nested path users/{uid}/orders/{id}
      // This root collection is for admin tracking and would typically be handled by a collectionGroup or a duplicated write
      allow update: if isAdmin();
    }

  }
}
