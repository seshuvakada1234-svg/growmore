
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Hardcoded failsafe for master admin email to prevent bootstrap lockouts
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'seshuvakada1234@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'
      ); 
    }
    
    function isAffiliate(userId) { return isSignedIn() && get(/databases/$(database)/documents/users/$(userId)).data.get('role', 'user') == 'affiliate'; }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || isOwner(userId);
    }

    // --- Roles DBAC ---
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Affiliate Profiles & Payouts ---
    match /affiliateProfiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
      allow update: if isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalClicks', 'updatedAt']);

      match /payouts/{payoutId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.status == 'pending';
        allow update: if isAdmin();
        allow delete: if false;
      }

      match /commissions/{commId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }
    }

    // --- Affiliate Flow (Applications) ---
    match /affiliateApplications/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // --- Global Click Logs ---
    match /affiliateClicks/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // --- Catalog ---
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders ---
    match /orders/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
    }

    // --- Collection Group Queries (Admin only) ---
    match /{path=**}/payouts/{id} {
      allow read: if isAdmin();
    }
    match /{path=**}/commissions/{id} {
      allow read: if isAdmin();
    }
  }
}
