rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'seshuvakada1234@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      ); 
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    function isApprovedAffiliate() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('affiliateApproved', false) == true;
    }

    // --- Admin Whitelist ---
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || isOwner(userId);

      // Subcollections for addresses and wishlist
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Affiliate Applications ---
    match /affiliateApplications/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create, update: if isOwner(userId) && 
        (request.resource.data.status == "pending" || request.resource.data.status == "submitted");
      allow delete: if isAdmin();
    }

    // --- Affiliate Profiles ---
    match /affiliateProfiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && 
        (
          // Allow creation with initial zero stats
          (
            request.resource.data.get('totalEarnings', 0) == 0 &&
            request.resource.data.get('withdrawableAmount', 0) == 0 &&
            request.resource.data.get('paidEarnings', 0) == 0 &&
            request.resource.data.get('approved', false) == false
          ) ||
          // OR allow updates that don't touch sensitive financial fields
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalEarnings', 'withdrawableAmount', 'approved', 'paidEarnings'])
        );
      
      // Subcollection for specific profiles
      match /payouts/{payoutId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isAdmin();
      }
    }

    // --- Collection Group for Payouts (Admin View) ---
    match /{path=**}/payouts/{payoutId} {
      allow read: if isAdmin();
    }

    // --- Affiliate Links ---
    match /affiliate_links/{linkId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isApprovedAffiliate() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Affiliate Clicks ---
    match /affiliateClicks/{clickId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // --- Affiliate Commissions ---
    match /affiliate_commissions/{commId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.affiliateId == request.auth.uid);
      allow create: if isSignedIn(); 
      allow update: if isAdmin();
      allow delete: if false;
    }

    // --- Withdraw Requests (Root Collection) ---
    match /affiliateWithdrawRequests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.affiliateId == request.auth.uid);
      allow create: if isApprovedAffiliate() && 
        request.resource.data.affiliateId == request.auth.uid &&
        request.resource.data.amount >= 500 &&
        request.resource.data.status == "pending";
      allow update: if isAdmin();
      allow delete: if false;
    }
    
    match /orders/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
    }
  }
}