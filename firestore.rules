
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Admin check: checks DBAC collection OR role field in user document
    // Using .get() with a default to prevent rule crashes if field is missing
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'
      ); 
    }
    
    function isAffiliate(userId) { return isSignedIn() && get(/databases/$(database)/documents/users/$(userId)).data.get('role', 'user') == 'affiliate'; }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || isOwner(userId);

      // --- Nested Affiliate Data (Siloed Pattern) ---
      match /affiliate/profile {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
        // Allow click increment via tracker
        allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalClicks', 'updatedAt']);

        match /commissions/{id} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isAdmin();
        }

        match /payouts/{id} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId) && isAffiliate(userId);
          allow update: if isAdmin();
        }
      }
    }

    // --- Roles DBAC ---
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Affiliate Flow (Applications) ---
    match /affiliateApplications/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // --- Global Click Logs ---
    match /affiliateClicks/{id} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // --- Catalog ---
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders ---
    match /orders/{id} {
      allow create: if isSignedIn() && (!('affiliateId' in request.resource.data) || request.resource.data.affiliateId != request.auth.uid);
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
    }

    // --- Collection Group Queries (Admin only) ---
    match /{path=**}/payouts/{id} {
      allow read: if isAdmin();
    }
    match /{path=**}/commissions/{id} {
      allow read: if isAdmin();
    }
  }
}
