
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); }
    function isAffiliate() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'affiliate'; }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin();
    }

    // --- Roles DBAC ---
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Affiliate Flow ---
    match /affiliateApplications/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /affiliateProfiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
      // Allow public increment of clicks
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalClicks']);
    }

    match /affiliateCommissions/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.affiliateId == request.auth.uid);
      allow create: if isSignedIn(); // System logs this during checkout
      allow update: if isAdmin();
    }

    match /affiliatePayouts/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.affiliateId == request.auth.uid);
      allow create: if isAffiliate() && request.resource.data.affiliateId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /affiliateClicks/{id} {
      allow create: if true; // Public tracking
      allow read: if isAdmin();
    }

    // --- Catalog ---
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders ---
    match /orders/{id} {
      allow create: if isSignedIn() && (!('affiliateId' in request.resource.data) || request.resource.data.affiliateId != request.auth.uid);
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
    }
  }
}
